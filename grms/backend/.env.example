# Environment variables for GRMS Backend

# Server
PORT=4000
DOORLINK_PORT=4001

# Database
DATABASE_URL=postgres://grms:grms@localhost:5432/grms?sslmode=disable

# JWT Secrets (CHANGE IN PRODUCTION!)
JWT_SECRET=grms-secret-key-change-in-production
JWT_STAFF_SECRET=grms-staff-secret-change-in-production

# Master key for AES-256 encryption (32 bytes hex)
# Generate with: openssl rand -hex 32
MASTER_KEY=0123456789abcdef0123456789abcdef
